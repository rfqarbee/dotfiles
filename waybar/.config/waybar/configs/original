{
    "layer" : "top", //always let top to display front of windows
    "modules-left" : ["hyprland/window"],
    "modules-center" : ["hyprland/workspaces"],
    "modules-right" : ["custom/cliphist", "group/control","custom/power"],


    "group/control" : {
      "orientation" : "horizontal",
      "modules" : [
          "wireplumber","network","custom/updates","clock"
      ]
    },

/*workspaces*/
    "hyprland/workspaces": {
        "format": "{icon} {name} {windows}",
        "window-rewrite-default": "яДР ",
        "show-special": true,
        "all-outputs" : true,
        "active-only" : false,
        "window-format": "<span>{windows}</span>",
        //special window
        "window-rewrite": {
            //browser
            "class<firefox>": "яЙй ",
            "class<firefox> title<.*Picture-in-Picture.*>" : "яЕД ",
            //word editor
            "class<obsidian>": "яЕЬ ",
            "class<.*libreoffice-writer.*>":"яЗВ ",
            "class<.*libreoffice-calc.*>":"яЗГ ",
            "class<.*libreoffice-draw.*>":"яЦо " ,
            "class<.*libreoffice-impress.*>":"яЗД ",
            "class<.*libreoffice-math.*>":"яЪШ ",
            //term
            "class<Alacritty>" : "яЕ╝ ",
            "class<kitty>" :"яТЙ ",
            //settings
            "class<pwvucontrol>" : "яАе ",
            "class<blueman-manager>" : "яКУ ",
            "class<qt5ct>" : "QT5",
            "class<qt6ct>" : "QT6",
            "class<nwg-look>" : "GTK",
            "class<nm-connection-editor>" : "яЫ┐ ",
            //steam
            "class<steam>" : "яЖ╢ ",
            "class<steam> title<.*Friends List.*>" : "яАЗ ",
            "class<steam> title<.*Friends List.*>" : "яАУ ",
            //discord
            "class<vesktop>" : "яОТ ",
            //misc
            "class<nemo>" : "яБ╗ ",
            "class<Display> title<.*ImageMagick.*>" : "яА╛ ",
            "class<mpv>" : "яЕД ",
            "class<Display> title<.*ImageMagick.*>" : "яА╛ ",
            "class<Nsxiv>" : "яА╛ "
        },
        "format-icons": {
            "1": "яВ▒ ",
            "2": "яДб ",
            "3": "яА║ ",
            "4": "яДЫ ",
            "5": "яАХ ",
            "6": "яЛТ ",
            "7": "яОТ ",
            "8": "яЖ╢ ",
            "9": "яГЛ ",
            "10": "яАУ ",
            "default": "яЛТ ",
            "special": "яГЖ "
            },
    },

    "hyprland/window" : {
        "format" : "{}",
         "rewrite": {
                "(.*) тАФ Mozilla Firefox": "яЙй ",
                "Alacritty": "яТЙ ",
                "zsh": "яТЙ ",
                "(.*) Discord (.*)" : "яОТ ",
                "Picture-in-Picture" : "яЕД ",
                "steam":"яЖ╢ ",
                "volume Control":"яАУ ",
               "blueman-manager":"яАУ ",
                "Home":"яБ╗ ",
            },
        "separate-outputs" : false
    },

/*must be member of the input group
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": {
            "numlock": "N {icon}",
            "capslock": "C {icon}"
        },
        "format-icons": {
            "locked": "яАг ",
            "unlocked": "яВЬ "
        }
    },
*/

/*time*/
    "clock": {
        "interval" : 1,
        "format" :"яАЧ {:%H:%M:%S %p яЧ╡ %a %d-%m}",
        "tooltip" : true,
        // "tooltip-format" : "{:%A, %B %d, %Y (%R)}",
        //"tooltip-format": "<span>Test</span>",
        //"actions" : {
        //    "on-click-right" :"mode"
        //}
    },

/*network*/
    "network": {
        "interface": "enp3s0",
        "format-ethernet": "яЗл  Nusa Time",
        "format-disconnected":"ґ░Цк No Internet",
        /*"tooltip-format-ethernet": "яГБ {ipaddr} {ifname}",*/
        /*"tooltip-format-disconnected": "ґ░Цк Disconnected",*/
        "max-length": 50
    },

/*audio*/
    "wireplumber": {
        "format": "{icon} {volume}%",
        "on-click": "pwvucontrol",
        "format-muted": "ґ░ЭЯ ",
        "states": {
            "muted": 0 ,
            "low": 10,
            "mid": 40,
            "high": 75,
        },
        "format-icons": ["яАж ", "яАз ", "яАи "],
        "scroll-step" : 1,
        "ignored-sinks": ["Easy Effects Sink"]
    },

/*
custom
    "custom/launcher" : {
        "format": "яМГ ",
        "on-click": "rofi -show drun -theme \"~/.config/rofi/launchers/sidebar/sidebar.rasi\" ",
        "on-click-right": "killall rofi"
    },

    "custom/updates": {
       "format" : "{} {icon}",
       "return-type": "json",
       "format-icons": {
       "has-updates": "яЖЗ ",
       "updated": "ґ░Вк "
       },
       "exec-if": "which waybar-module-pacman-updates",
       "exec": "waybar-module-pacman-updates  --interval-seconds 5 --network-interval-seconds 300"
   },
*/

 "custom/power":{
     "format":"яАС ",
     "on-click":"wlogout --protocol layer-shell"
     },

  "custom/cliphist" :{
    "format" :"ґ▒Уе ",
    "tooltip":false,
    "on-click": "~/.local/scripts/clipboard.sh"
  },


/*later*/
    "cpu": {
        "interval": 15,
        "format": "яЛЫ {}%",
        "max-length": 10
    },

    "memory": {
        "interval": 30,
        "format": "яГЙ {}%",
        "max-length": 10
    },

    "group/system" : {
        "orientation" : "horizontal",
        "modules" : [
            "cpu",
            "memory"
        ]
    }
}
