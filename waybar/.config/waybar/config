{
    "layer" : "top", //always let top to display front of windows
    "modules-left" : ["custom/launcher","hyprland/workspaces"],
    "modules-center" : ["hyprland/window"],
    "modules-right" : ["custom/cliphist","custom/updates","group/control","custom/power"],


    "group/control" : {
      "orientation" : "horizontal",
      "modules" : [
          "wireplumber","network","clock"
      ]
    },

/*workspaces*/
    "hyprland/workspaces": {
        "format": "{name} {windows}",
        "window-rewrite-default": "п„‘ " ,
        "window-format": "<span>{windows}</span>",
        "window-rewrite": {
            "class<firefox>": "п‰© ",
            "class<vesktop>": "пЋ’ ",
            "class<alacritty>": "оћ•",
            "class<kitty>": "оћ• ",
            "class<steam>":"п†¶ ",
            "class<pavucontrol>":"пЂ“ ",
            "class<nemo>":"пЃ» ",
        },
        "persistent-workspaces": {
            "*": 2, // 2 workspaces by default on every monitor
            "DP-1" : [1,2],
            "DP-2" : [3,4,5,6]
        },
        "format-icons": {
            "1": "оћ• ",
            "2": "п‰© ",
            "3": "п„Ў ",
            "4": "п†ј ",
            "5": "пЃµ ",
            "default": "п„‘ "
        },
    },

    "hyprland/window" : {
        "format" : "{}",
         "rewrite": {
                "(.*) вЂ” Mozilla Firefox": "п‰© ",
                "Alacritty": "п’‰ ",
                "(.*) Discord (.*)" : "пЋ’ ",
                "steam":"п†¶ ",
                "volume Control":"пЂ“ ",
                "Home":"пЃ» ",
            },
        "separate-outputs" : true
    },

/*must be member of the input group*/
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": {
            "numlock": "N {icon}",
            "capslock": "C {icon}"
        },
        "format-icons": {
            "locked": "пЂЈ ",
            "unlocked": "п‚њ "
        }
    },

/*time*/
    "clock": {
        "interval" : 1,
        "format" :"пЂ— {:%H:%M:%S %p п—µ %a %d-%m}",
        "tooltip" : true,
        // "tooltip-format" : "{:%A, %B %d, %Y (%R)}",
        //"tooltip-format": "<span>Test</span>",
        //"actions" : {
        //    "on-click-right" :"mode"
        //}
    },

/*network*/
    "network": {
        "interface": "enp3s0",
        "format-ethernet": "п‡«  Nusa Time",
        "tooltip-format-ethernet": "пѓЃ {ipaddr} {ifname}",
        "tooltip-format-disconnected": "у°–Є Disconnected",
        "max-length": 50
    },

/*audio*/
    "wireplumber": {
        "format": "{icon} {volume}%",
        "on-click": "pavucontrol",
        "format-muted": "у°ќџ ",
        "states": {
            "muted": 0 ,
            "low": 10,
            "mid": 40,
            "high": 75,
        },
        "format-icons": ["пЂ¦ ", "пЂ§ ", "пЂЁ "],
        "scroll-step" : 1,
        "ignored-sinks": ["Easy Effects Sink"]
    },

/*custom*/
    "custom/launcher" : {
        "format": "пЊѓ ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi"
    },

    "custom/updates": {
       "format": "{icon} {}",
       "return-type": "json",
       "format-icons": {
       "has-updates": "п†‡ ",
            "updated": "у°‚Є "
       },
       "exec-if": "which waybar-module-pacman-updates",
       "exec": "waybar-module-pacman-updates  --interval-seconds 5 --network-interval-seconds 300"
   },

 "custom/power":{
     "format":"пЂ‘ ",
     "on-click":"wlogout --protocol layer-shell"
     },

  "custom/cliphist" :{
    "format" :"у±“Ґ ",
    "tooltip":false,
    "on-click": "cliphist list | rofi -dmenu | cliphist decode | wl-copy"
  },


/*later*/
    "cpu": {
        "interval": 15,
        "format": "п‹› {}%",
        "max-length": 10
    },

    "memory": {
        "interval": 30,
        "format": "пѓ‰ {}%",
        "max-length": 10
    },

    "group/system" : {
        "orientation" : "horizontal",
        "modules" : [
            "cpu",
            "memory"
        ]
    }
}
