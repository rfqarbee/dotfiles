{
    "layer" : "top", //always let top to display front of windows
    "modules-left" : ["custom/launcher","hyprland/window"],
    "modules-center" : ["hyprland/workspaces"],
    "modules-right" : ["custom/cliphist","group/control","custom/power"],


    "group/control" : {
      "orientation" : "horizontal",
      "modules" : [
          "wireplumber","network","custom/updates","clock"
      ]
    },

/*workspaces*/
    "hyprland/workspaces": {
        "format": "{icon} {name} {windows}",
        "window-rewrite-default": "ΎΕΡ ",
        "show-special": true,
        "active-only" : false,
        "window-format": "<span>{windows}</span>",
        //special window
        "window-rewrite": {
            //browser
            "class<firefox>": "ΎΚσ ",
            "class<firefox> title<.*Picture-in-Picture.*>" : "ΎΖΕ ",
            //word editor
            "class<obsidian>": "ΎΖε ",
            "class<.*libreoffice-writer.*>":"ΎΘΓ ",
            "class<.*libreoffice-calc.*>":"ΎΘΔ ",
            "class<.*libreoffice-draw.*>":"ΎΨχ " ,
            "class<.*libreoffice-impress.*>":"ΎΘΕ ",
            "class<.*libreoffice-math.*>":"Ύγα ",
            //term
            "class<Alacritty>" : "ΎΖ╝ ",
            "class<kitty>" :"ΎΤΚ ",
            //settings
            "class<pavucontrol>" : "ΎΑξ ",
            "class<blueman-manager>" : "ΎΛΥ ",
            "class<qt5ct>" : "QT5",
            "class<qt6ct>" : "QT6",
            "class<nwg-look>" : "GTK",
            "class<nm-connection-editor>" : "Ύδ┐ ",
            //steam
            "class<steam>" : "ΎΗ╢ ",
            "class<steam> title<.*Friends List.*>" : "ΎΑΘ ",
            "class<steam> title<.*Friends List.*>" : "ΎΑΥ ",
            //discord
            "class<vesktop>" : "ΎΟΤ ",
            //misc
            "class<nemo>" : "ΎΒ╗ ",
            "class<Display> title<.*ImageMagick.*>" : "ΎΑ╛ ",
            "class<mpv>" : "ΎΖΕ ",
            "class<Nsxiv>" : "ΎΑ╛ "
        },
        "format-icons": {
            "1": "ΎΓ▒ ",
            "2": "ΎΑ║ ",
            "3": "ΎΕδ ",
            "4": "ΎΑΧ ",
            "5": "ΎΕκ ",
            "6": "ΎΜΤ ",
            "7": "ΎΟΤ ",
            "8": "ΎΗ╢ ",
            "9": "ΎΔΜ ",
            "10": "ΎΑΥ ",
            "default": "ΎΜΤ ",
            "special": "ΎΔΗ "
            },
    },

    "hyprland/window" : {
        "format" : "{}",
         "rewrite": {
                "(.*) έΑΦ Mozilla Firefox": "ΎΚσ ",
                "Alacritty": "ΎΤΚ ",
                "zsh": "ΎΤΚ ",
                "(.*) Discord (.*)" : "ΎΟΤ ",
                "Picture-in-Picture" : "ΎΖΕ ",
                "steam":"ΎΗ╢ ",
                "volume Control":"ΎΑΥ ",
                "blueman-manager":"ΎΑΥ ",
                "Home":"ΎΒ╗ ",
            },
        "separate-outputs" : true
    },

/*must be member of the input group
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": {
            "numlock": "N {icon}",
            "capslock": "C {icon}"
        },
        "format-icons": {
            "locked": "ΎΑμ ",
            "unlocked": "ΎΓε "
        }
    },
*/

/*time*/
    "clock": {
        "interval" : 1,
        "format" :"ΎΑΩ {:%H:%M:%S %p ΎΩ╡ %a %d-%m}",
        "tooltip" : true,
        // "tooltip-format" : "{:%A, %B %d, %Y (%R)}",
        //"tooltip-format": "<span>Test</span>",
        //"actions" : {
        //    "on-click-right" :"mode"
        //}
    },

/*network*/
    "network": {
        "interface": "enp3s0",
        "format-ethernet": "ΎΘτ  Nusa Time",
        "tooltip-format-ethernet": "ΎΔΒ {ipaddr} {ifname}",
        "tooltip-format-disconnected": "≤░Ψς Disconnected",
        "max-length": 50
    },

/*audio*/
    "wireplumber": {
        "format": "{icon} {volume}%",
        "on-click": "pavucontrol",
        "format-muted": "≤░ζθ ",
        "states": {
            "muted": 0 ,
            "low": 10,
            "mid": 40,
            "high": 75,
        },
        "format-icons": ["ΎΑο ", "ΎΑπ ", "ΎΑρ "],
        "scroll-step" : 1,
        "ignored-sinks": ["Easy Effects Sink"]
    },

/*custom*/
    "custom/launcher" : {
        "format": "ΎΝΔ ",
        "on-click": "~/.config/rofi/launchers/type-6/launcher.sh",
        "on-click-right": "killall rofi"
    },

    "custom/updates": {
       "format": "{icon} {}",
       "return-type": "json",
       "format-icons": {
       "has-updates": "ΎΗΘ ",
            "updated": "≤░Γς "
       },
       "exec-if": "which waybar-module-pacman-updates",
       "exec": "waybar-module-pacman-updates  --interval-seconds 5 --network-interval-seconds 300"
   },

 "custom/power":{
     "format":"ΎΑΣ ",
     "on-click":"wlogout --protocol layer-shell"
     },

  "custom/cliphist" :{
    "format" :"≤▒Υξ ",
    "tooltip":false,
    "on-click": "~/.local/scripts/clipboard.sh"
  },


/*later*/
    "cpu": {
        "interval": 15,
        "format": "ΎΜδ {}%",
        "max-length": 10
    },

    "memory": {
        "interval": 30,
        "format": "ΎΔΚ {}%",
        "max-length": 10
    },

    "group/system" : {
        "orientation" : "horizontal",
        "modules" : [
            "cpu",
            "memory"
        ]
    }
}
