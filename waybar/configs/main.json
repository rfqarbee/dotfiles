{
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal"
  },

  "disk": {
    "interval": 3600,
    "format": "{specific_free:0.0f}GB/{specific_total:0.0f}GB",
    "unit": "GB",
    "path": "/home"
  },

  "backlight": {
    "interval": 2,
    "align": 0,
    "rotate": 0,
    "format-icons": [
      "ΌΠΧ ",
      "ΌΠΩ ",
      "ΌΠγ ",
      "≤░Δζ ",
      "≤░Δη ",
      "≤░Δθ ",
      "≤░Δι "
    ],
    "format": "{icon}",
    //"format-icons": ["ΌΠΧ","ΌΠΨ","ΌΠΩ","ΌΠα","ΌΠβ","ΌΠγ","ΌΠδ","ΌΠε","ΌΠζ","ΌΠη","ΌΠθ","ΌΠι","ΌΠκ","ΌΠλ","ΌΠμ"],
    "tooltip-format": "backlight {percent}%",
    "icon-size": 10,
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "$LOCAL_DIR/scripts/brightness.sh --inc",
    "on-scroll-down": "$LOCAL_DIR/scripts/brightness.sh --dec",
    "smooth-scrolling-threshold": 1,
  },

  "bluetooth": {
    "format": "ΎΛΥ ",
    "format-disabled": "≤░Γ│",
    "format-connected": "≤░Γ▒ {num_connections}",
    "tooltip-format": "ΎΛΥ {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "blueman-manager",
  },

  "clock": {
    "interval": 1,
    "format" :"{:%d/%b %a %H:%M }",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },

  "cpu": {
    "interval": 10,
    "format": "{}% ΎΜδ",
    "max-length": 10
  },

  "memory": {
    "interval": 10,
    "format": "{percentage}% ≤░╛Η",
    "format-alt": "{used:0.1f}G ≤░╛Η",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "≤░Να",
    "format-disconnected": "≤░Νβ",
    "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBits} ΎΕ║ {bandwidthDownBits}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 30,
    "format-icons": [
      "≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"
    ],
    "on-click-right": "kitty nmtui"
  },

  "power-profiles-daemon": {
    "format": "{icon} ",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} ≤░Γ░ {volume}%",
    "format-muted": "≤░ΨΒ",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο", "ΎΑπ", "≤░Χ╛",  "ΎΑρ"
      ],
      "ignored-sinks": [
        "Easy Effects Sink"
      ],
    },
    "scroll-step": 5.0,
    "on-click-right": "$LOCAL_DIR/scripts/volume.sh --toggle",
    "on-click": "pavucontrol -t 3",
    "on-scroll-up": "$LOCAL_DIR/scripts/volume.sh --inc",
    "on-scroll-down": "$LOCAL_DIR/scripts/volume.sh --dec",
    "tooltip-format": "{icon} {desc} | {volume}%",
    "smooth-scrolling-threshold": 1,
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "on-click-right": "$LOCAL_DIR/scripts/volume.sh --toggle-mic",
    "on-click": "pavucontrol -t 4",
    "on-scroll-up": "$LOCAL_DIR/scripts/volume.sh --mic-inc",
    "on-scroll-down": "$LOCAL_DIR/scripts/volume.sh --mic-dec",
    "tooltip-format": "{source_desc} | {source_volume}%",
    "scroll-step": 5,
  },

  "tray": {
    "icon-size": 20,
    "spacing": 4,
  },

}

